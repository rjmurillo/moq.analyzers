<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <RootNamespace>Moq.Analyzers</RootNamespace>
    <AssemblyName>Moq.Analyzers</AssemblyName>
    <IsPackable>false</IsPackable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoWarn>$(NoWarn);RS1038</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.AnalyzerUtilities" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(RepoRoot)/src/Analyzers/**/*.cs" />
    <Compile Include="$(RepoRoot)/src/CodeFixes/**/*.cs" />
    <Compile Include="$(RepoRoot)/src/Common/**/*.cs" />
    <EmbeddedResource Include="$(RepoRoot)/src/Analyzers/Resources.resx" />
    <AdditionalFiles Include="$(RepoRoot)/src/Analyzers/AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="$(RepoRoot)/src/Analyzers/AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
</Project>

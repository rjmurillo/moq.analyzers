<Project>
  <!--
    Automatically configure git to use .githooks/ as the hooks directory.
    Queries git config directly instead of a sentinel file, so this works
    in worktrees and submodules where .git may be a file, not a directory.
    Respects any existing core.hooksPath value (does not clobber).
    Skips design-time builds and CI.
  -->
  <Target
    Name="ConfigureGitHooks"
    BeforeTargets="Restore;Build"
    Condition=" '$(DesignTimeBuild)' != 'true' AND '$(ContinuousIntegrationBuild)' != 'true' AND Exists('$(RepoRoot).git') ">

    <Exec
      Command="git config core.hooksPath"
      WorkingDirectory="$(RepoRoot)"
      ConsoleToMsBuild="true"
      IgnoreExitCode="true"
      StandardOutputImportance="low">
      <Output TaskParameter="ExitCode" PropertyName="_HooksPathExitCode" />
    </Exec>

    <!-- Only set when core.hooksPath is not configured (exit code 1) -->
    <Exec
      Condition=" '$(_HooksPathExitCode)' != '0' "
      Command="git config core.hooksPath .githooks"
      WorkingDirectory="$(RepoRoot)"
      IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_SetHooksExitCode" />
    </Exec>

    <Message
      Condition=" '$(_HooksPathExitCode)' != '0' AND '$(_SetHooksExitCode)' == '0' "
      Importance="high"
      Text="Git hooks configured. Run 'git config --unset core.hooksPath' to disable." />
  </Target>
</Project>
